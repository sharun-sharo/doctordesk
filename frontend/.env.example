# Backend API URL (used at build time). Required for production.
# Local:
VITE_API_URL=http://localhost:5000/api/v1

# Production (e.g. Vercel): set this to your backend URL so clients can reach the API.
# Example (Railway): VITE_API_URL=https://your-backend.up.railway.app/api/v1
# Without this, production builds try to call localhost and users get "Network error".

# Optional: label for the default doctor in New Appointment (e.g. "Main Clinic", "City Clinic")
# VITE_CLINIC_NAME=Clinic
