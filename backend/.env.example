# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Optional: clinic name shown on invoice PDF (default: DoctorDesk)
# CLINIC_NAME=My Clinic

# Database (GoDaddy MySQL - use remote host in production)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=clinic_management

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (for CORS). Use 5174 if Vite uses that port.
FRONTEND_URL=http://localhost:5173

# Email (for forgot password - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@clinic.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMS (Twilio) - optional; for appointment reminders and Send SMS to patient
# Get credentials from https://console.twilio.com . Use a Twilio phone number (e.g. +1234567890) for TWILIO_SMS_FROM.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
